@page "/clientes"
@using System.Globalization
@using System.Net.Http.Json
@using BlazorAppSeuz.IServices
@using BlazorAppSeuz.Services
@using BlazorAppZeuz.Models.Zeuz
@inject IClienteService ClienteService
@inject ISnackbar Snackbar
@inject NavigationManager NavManager
@inject IJSRuntime JS
  
<MudTable Outlined="true" 
                  @ref="table"
                  EditMode="DataGridEditMode.Row"
                  Items="@clientes"
                  Dense="false"
                  Hover="true"
                  Bordered="false"
                  Striped="false"
                  CanCancelEdit="true"
                  ReadOnly="false"
                  EditTrigger="TableEditTrigger.EditButton"
                  EditButtonPosition="TableEditButtonPosition.End"
                  ApplyButtonPosition="TableApplyButtonPosition.End"
                  IsEditRowSwitchingBlocked="true"
                  Filter="new Func<Tclientesb, bool>(FilterFunc)"
                  RowEditCommit="ItemHasBeenCommitted" 
                  RowEditPreview="BackupItem"
                  RowEditCancel="ResetItemToOriginalValues"
                  @bind-SelectedItem="selectedUser">


            <ToolBarContent>
                 
                <MudText Typo="Typo.h6">Maestro de clientes</MudText>

         
                <MudSpacer />

                <MudTextField @bind-Value="searchString"
                              Placeholder="Buscar"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Class="mt-0" />
      
            </ToolBarContent>

            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<Tclientesb, object>(x=>x.ClievIdcliente)">ID Cliente</MudTableSortLabel></MudTh>

                <MudTh><MudTableSortLabel SortBy="new Func<Tclientesb, object>(x=>x.ClievNombre)">Nombre</MudTableSortLabel></MudTh>

                <MudTh><MudTableSortLabel SortBy="new Func<Tclientesb, object>(x=>x.ClievPropietario)">Propietario</MudTableSortLabel></MudTh>

                <MudTh><MudTableSortLabel SortBy="new Func<Tclientesb, object>(x=>x.ClievEncargado)">Encargado</MudTableSortLabel></MudTh>

                <MudTh><MudTableSortLabel SortBy="new Func<Tclientesb, object>(x=>x.ClievDireccion2)">Dirección</MudTableSortLabel></MudTh>
                
                <MudTh><MudTableSortLabel SortBy="new Func<Tclientesb, object>(x=>x.ClievDireccion3)">Dirección</MudTableSortLabel></MudTh>

                <MudTh><MudTableSortLabel SortBy="new Func<Tclientesb, object>(x=>x.ClievDireccion4)">Dirección</MudTableSortLabel></MudTh>

                <MudTh><MudTableSortLabel SortBy="new Func<Tclientesb, object>(x=>x.ClievDireccion5)">Dirección</MudTableSortLabel></MudTh>

                <MudTh><MudTableSortLabel SortBy="new Func<Tclientesb, object>(x=>x.ClienLatitud)">Latitud</MudTableSortLabel></MudTh>

                <MudTh><MudTableSortLabel SortBy="new Func<Tclientesb, object>(x=>x.ClienLongitud)">Longitud</MudTableSortLabel></MudTh>

                <MudTh>Mapa</MudTh>
            </HeaderContent>
             
            <RowTemplate>

                <MudTd DataLabel="ID Cliente">@context.ClievIdcliente</MudTd>
                <MudTd DataLabel="Nombre">@context.ClievNombre</MudTd>
                <MudTd DataLabel="Propietario">@context.ClievPropietario</MudTd>
                <MudTd DataLabel="Encargado">@context.ClievEncargado</MudTd>
                <MudTd DataLabel="Dirección">@context.ClievDireccion2</MudTd>
                <MudTd DataLabel="Dirección">@context.ClievDireccion3</MudTd>
                <MudTd DataLabel="Dirección">@context.ClievDireccion4</MudTd>
                <MudTd DataLabel="Dirección">@context.ClievDireccion5</MudTd>
                <MudTd DataLabel="Latitud">@context.ClienLatitud</MudTd>
                <MudTd DataLabel="Longitud">@context.ClienLongitud</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Map"
                                   Color="Color.Primary"
                                   OnClick="@(() => AbrirMapa(context.ClienLatitud, context.ClienLongitud))" />
                </MudTd>
                
            </RowTemplate>

            <RowEditingTemplate>

                <MudTd DataLabel="Id Camion">
                    <MudTextField @bind-Value="context.ClievIdcliente" Required="true" Disabled="true"  />
                </MudTd>

                <MudTd DataLabel="Nombre">
                    <MudTextField @bind-Value="context.ClievNombre" Required="true" />
                </MudTd>
 
                <MudTd DataLabel="Propietario">
                    <MudTextField @bind-Value="context.ClievPropietario"
                                  Required="false" />
                </MudTd>
 
                <MudTd DataLabel="Encargado">
                    <MudTextField @bind-Value="context.ClievEncargado" />
                </MudTd>
                
                <MudTd DataLabel="Dirección">
                    <MudTextField @bind-Value="context.ClievDireccion2" />
                </MudTd>
                
                <MudTd DataLabel="Dirección">
                    <MudTextField @bind-Value="context.ClievDireccion3" />
                </MudTd>
                
                <MudTd DataLabel="Dirección">
                    <MudTextField @bind-Value="context.ClievDireccion4" />
                </MudTd>
                
                <MudTd DataLabel="Dirección">
                    <MudTextField @bind-Value="context.ClievDireccion5" />
                </MudTd>
                
                <MudTd DataLabel="Latitud">
                    <MudTextField @bind-Value="context.ClienLatitud" />
                </MudTd>
                
                <MudTd DataLabel="longitud">
                    <MudTextField @bind-Value="context.ClienLongitud" />
                </MudTd>
                
               
 
            </RowEditingTemplate>
            
            <PagerContent>

                <MudTablePager>
           
                </MudTablePager>
          
            </PagerContent>
 

        </MudTable>

        

@code {

    private MudTable<Tclientesb> table;
    private bool isEditing = false;
    private bool _showDeletedUsers;

    private bool showDeletedUsers
    {
        get => _showDeletedUsers;
        set
        {
            if (_showDeletedUsers != value)
            {
                _showDeletedUsers = value;
                OnShowDeletedChanged();
            }
        }
    }

    private async Task OnShowDeletedChanged()
    {
        // ejemplo: recargar datos
        await LoadUsers();
    }

    private string searchString = "";
    public string passwordX = Constants.passwordxxx;
    private Tclientesb? selectedUser;

    private Tclientesb elementBeforeEdit;


    private List<Tclientesb> clientes = new();

    private async Task LoadUsers()
    {
        clientes = await ClienteService.GetAllAsync();
 
        StateHasChanged();
    }
     
    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadUsers();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error cargando usuarios: {ex.Message}", Severity.Error);
        }
    }

    private async Task AddNewUser()
    {
    }

    private async Task DeleteItem(Tcamiones user)
    {
    }

    private async void BackupItem(object element)
    {
        isEditing = true;
       
        elementBeforeEdit = new()
        {
           
           // UsuavPassword = Constants.passwordxxx,
          
        };
        
        StateHasChanged();
    }

    private async void ResetItemToOriginalValues(object element)
    {
        isEditing = false;
        await LoadUsers();
        StateHasChanged();
    }

    private async void ItemHasBeenCommitted(object userObj)
    {

        try
        {
            
            var user = (Tclientesb)userObj;

            

            if (user.ClievIdcliente.Equals(0))
            {
                // ES NUEVO → CREATE
                //await UserService.CreateAsync(user);
                Snackbar.Add("User created", Severity.Success);

                isEditing = false;
               
            }
            else
            {
                // EXISTENTE → UPDATE
                await ClienteService.UpdateAsync(user);
                Snackbar.Add("Usuario actualizado", Severity.Success);
            }

            isEditing = false;
            await LoadUsers();
            StateHasChanged();

        }
        catch
        {
            Snackbar.Add("Error updating the user", Severity.Error);
           
        }
    }

    private async Task UpdateItem(Tcamiones user)
    {
        try
        {
           // await UserService.UpdateAsync(user.Id, user);
            await LoadUsers();
            Snackbar.Add("User updated", Severity.Success);
           

        }
        catch
        {
            Snackbar.Add("Error updating the user", Severity.Error);
        }
    }

    private bool FilterFunc(Tclientesb camion)
    {
        return new[]
            {
                camion.ClievIdcliente,
                camion.ClievNombre,
                camion.ClievEncargado,
                camion.ClievPropietario,
                camion.ClienLatitud?.ToString(),
                camion.ClienLongitud?.ToString(),
                
            }
            .Any(x => (x ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase));
    }
    
    private async Task AbrirMapa(decimal? latitud, decimal? longitud)
    {
        if (latitud == null || longitud == null)
        {
            Snackbar.Add("Cliente sin coordenadas", Severity.Warning);
            return;
        }
        var lat = Convert.ToDecimal(latitud).ToString(CultureInfo.InvariantCulture);
        var lng = Convert.ToDecimal(longitud).ToString(CultureInfo.InvariantCulture);
        var url = $"https://www.google.com/maps?q={lat},{lng}";

        await JS.InvokeVoidAsync("open", url, "_blank");
    }

}