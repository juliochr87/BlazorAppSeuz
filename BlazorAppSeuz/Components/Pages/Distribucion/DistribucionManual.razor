@page "/distribucionManual"
@using BlazorAppSeuz.IServices
@using BlazorAppZeuz.Dto.NotasEntrega
@inject INotasEntregaService NotasEntregaService
@inject ICamionService CamionService
@using BlazorAppZeuz.Models.Zeuz
@inject ISnackbar Snackbar

 <MudGrid AlignItems="AlignItems.Center" Class="mb-4">

    <MudItem xs="12" sm="6" md="3">
        <MudDatePicker @bind-Date="_selectedDate"
                       Margin="Margin.Dense"
                       Variant="Variant.Outlined"
                       Label="Fecha de emisión" />
    </MudItem>

    <MudItem xs="12" sm="6" md="2" Class="d-flex align-center">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Search"
                   FullWidth="true"
                   Style="height: 40px;" OnClick="Buscar">
            Buscar
        </MudButton>
    </MudItem>

    <MudItem xs="12" md="12" Class="d-flex flex-wrap justify-start gap-2 mt-2">
        
        <MudMenu StartIcon="@Icons.Material.Filled.AutoFixHigh" 
                 Label="Distribución Automática" 
                 Color="Color.Secondary" 
                 Variant="Variant.Filled"
                 EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                 Disabled="@(notasEntrega == null || !notasEntrega.Any() || camiones == null || !camiones.Any())">
                 
            <MudMenuItem OnClick="DistribuirPorPeso" 
                         Icon="@Icons.Material.Filled.Scale">Optimizar por Peso</MudMenuItem>
                         
            <MudMenuItem OnClick="DistribuirPorVolumen" 
                         Icon="@Icons.Material.Filled.Layers">Optimizar por Volumen</MudMenuItem>
                         
            <MudMenuItem OnClick="DistribuirPorPesoYVolumen" 
                         Icon="@Icons.Material.Filled.AllInclusive">Optimizar por Ambos (Estricto)</MudMenuItem>
        </MudMenu>

        <MudButton Variant="Variant.Outlined" 
                   Color="Color.Dark"
                   OnClick="ReiniciarDistribucion">
            Reiniciar Pantalla
        </MudButton>

        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@(camiones == null || !camiones.Any(c => c.NotasAsignadas.Any()))"
                   >
            Confirmar y Guardar Despacho
        </MudButton>
        
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Success" 
                   StartIcon="@Icons.Material.Filled.Add"
                   Disabled="@(camionSeleccionado == null || !notasSeleccionadas.Any())"
                   OnClick="AsignarNotasACamion">
            Asignar (@notasSeleccionadas.Count) al Camión @(camionSeleccionado?.Placa)
        </MudButton>
        
    </MudItem>
    
</MudGrid>
<br/>

<MudPaper Class="pa-4 mb-4" Elevation="3">
    <MudText Typo="Typo.h6" Class="mb-3">Flota Disponible</MudText>
    
   <MudGrid Spacing="2">
    @if (camiones != null)
    {
        @foreach (var camion in camiones)
        {
            <MudItem xs="6" sm="4" md="3" lg="2">
                <MudCard Elevation="@(camionSeleccionado == camion ? 8 : 1)"
                         Style="cursor: pointer; transition: 0.2s;"
                         Class="@(camionSeleccionado == camion ? "border-solid border-2 mud-border-primary" : "")"
                         @onclick="() => SeleccionarCamion(camion)">
                    
                  <MudCardContent Class="pa-2">
                      
                      <div class="d-flex align-center justify-space-between mb-1">
                          <MudText Typo="Typo.body2" Style="font-weight: bold;">
                              <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Class="mr-1 mb-n1"/>
                              @camion.Placa
                          </MudText>
    
                          <div class="d-flex align-center">
                              <MudText Typo="Typo.caption" Color="Color.Primary" Class="mr-1">
                                  <b>@camion.NotasAsignadas.Count notas</b>
                              </MudText>
                              <MudIconButton Icon="@Icons.Material.Filled.FormatListBulleted" 
                                             Size="Size.Small" 
                                             Color="Color.Primary"
                                             OnClick="() => AbrirDetalleCamion(camion)" />
                          </div>
                      </div>
                       
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block text-truncate mb-2">
                            @camion.NombreDespachador
                        </MudText>

                        <div class="d-flex justify-space-between mb-2 pa-1" style="background-color: var(--mud-palette-background-grey); border-radius: 4px;">
                            <MudText Typo="Typo.caption" Style="font-size: 0.70rem;">
                                📦 Cajas: <b>@camion.TotalCajas.ToString("N0")</b>
                            </MudText>
                            <MudText Typo="Typo.caption" Style="font-size: 0.70rem;">
                                🛒 Artículos: <b>@camion.TotalArticulos.ToString("N0")</b>
                            </MudText>
                        </div>

                        <div class="d-flex justify-space-between align-end">
                            <MudText Typo="Typo.caption" Style="font-size: 0.70rem;">
                                Peso: @camion.PesoActual.ToString("0.##") kg
                            </MudText>
                            <MudText Typo="Typo.caption" Style="font-size: 0.70rem;">
                                @camion.CapacidadPesoKg.ToString("0.##") kg
                            </MudText>
                        </div>
                        <MudProgressLinear Value="@camion.PorcentajePeso" 
                                           Color="@ObtenerColorCarga(camion.PorcentajePeso)" 
                                           Size="Size.Small" 
                                           Class="mb-2" />

                        <div class="d-flex justify-space-between align-end">
                            <MudText Typo="Typo.caption" Style="font-size: 0.70rem;">
                                Vol: @camion.VolumenActual.ToString("N2") m³
                            </MudText>
                            <MudText Typo="Typo.caption" Style="font-size: 0.70rem;">
                                @camion.CapacidadVolumen.ToString("N2") m³
                            </MudText>
                        </div>
                        <MudProgressLinear Value="@camion.PorcentajeVolumen" 
                                           Color="@ObtenerColorCarga(camion.PorcentajeVolumen)" 
                                           Size="Size.Small" />
                        
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    }
</MudGrid>


</MudPaper>
 
<MudTable Outlined="true"
          @ref="table"
          T="NotaEntregaDto"
          MultiSelection="true"
          @bind-SelectedItems="notasSeleccionadas" 
          Items="@notasEntrega"
          Dense="true"
          Hover="true"
          Loading="@loading"
          LoadingIndicator="true"
          Filter="new Func<NotaEntregaDto, bool>(FilterFunc)">

    <ToolBarContent>

        <MudText Typo="Typo.h6">
            Notas de entrega
        </MudText>

        <MudSpacer />

        <MudTextField @bind-Value="searchString"
                      Placeholder="Buscar"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Class="mt-0" />

    </ToolBarContent>

    <!-- HEADER -->
    <HeaderContent>
        <MudTh></MudTh>
        <MudTh>Documento</MudTh>
        <MudTh>RIF</MudTh>
        <MudTh>Razón Social</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Fecha Emisión</MudTh>
        <MudTh>Total cajas</MudTh>
        <MudTh>Total artículos</MudTh>
        <MudTh>Peso total</MudTh>
        <MudTh>Volumen total</MudTh>
        <MudTh>Comentarios</MudTh>
    </HeaderContent>

    <!-- ROW PRINCIPAL -->
    <RowTemplate Context="nota">

        <!-- BOTÓN EXPANDIR -->
        <MudTd>
            <MudIconButton Icon="@(expandedDocumento == nota.Documento
                                        ? Icons.Material.Filled.ExpandLess
                                        : Icons.Material.Filled.ExpandMore)"
                           OnClick="@(() => ToggleDetalle(nota))" />
        </MudTd>

        <MudTd>@nota.Documento</MudTd>
        <MudTd Style="@ObtenerEstiloPorCliente(nota)">@nota.Rif</MudTd>
        <MudTd Style="@ObtenerEstiloPorCliente(nota)">@nota.RazonSocial</MudTd>
        <MudTd>@nota.Status</MudTd>
        <MudTd>@nota.FechaEmision.ToString("dd/MM/yyyy")</MudTd>
        <MudTd>@nota.CajasTotal.ToString("N2")</MudTd>
        <MudTd>@nota.LineasTotal.ToString("N2")</MudTd>
        <MudTd>@nota.PesoTotal.ToString("N2")</MudTd>
        <MudTd>@nota.VolumenTotal.ToString("N2")</MudTd>
        <MudTd>@nota.Comentarios</MudTd>
      

    </RowTemplate>

    <!-- DETALLE EXPANDIBLE -->
    <ChildRowContent Context="nota">

        @if (expandedDocumento == nota.Documento)
        {
            <MudTr>
                <td colspan="7">

                    <MudPaper Class="pa-3">

                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                            Detalle de @nota.Documento
                        </MudText>

                        <MudTable T="DetalleNotaDTO"
                                  Dense="true"
                                  Hover="true"
                                  Bordered="true"
                                  Items="@(detalles.ContainsKey(nota.Documento)
                                            ? detalles[nota.Documento]
                                            : new List<DetalleNotaDTO>())">

                            <HeaderContent>
                                <MudTh>Id artículo</MudTh>
                                <MudTh>Artículo</MudTh>
                                <MudTh>Cajas</MudTh>
                                <MudTh>Unidades</MudTh>
                                <MudTh>Peso total</MudTh>
                                <MudTh>Volumen total</MudTh>
                                <MudTh>Status</MudTh>
                                
                            </HeaderContent>

                            <RowTemplate Context="item">
                                <MudTd>@item.IdArticulo</MudTd>
                                <MudTd>@item.Descripcion</MudTd>
                                <MudTd>@item.Cajas</MudTd>
                                <MudTd>@item.Unidades.ToString("N2")</MudTd>
                                <MudTd>
                                    <MudTooltip Text=@($"Peso unitario: {item.PesoUnitario:N2}")>
                                        @item.PesoTotal.ToString("N2")
                                    </MudTooltip>
                                </MudTd>
                              
                                <MudTd>
                                    <MudTooltip Text=@($"Volumen unitario: {item.VolumenUnitario:N2}")>
                                        @item.VolumenTotal.ToString("N2")
                                    </MudTooltip>
                                </MudTd>
                              
                                <MudTd>@item.Status</MudTd>
                            </RowTemplate>

                        </MudTable>

                    </MudPaper>

                </td>
            </MudTr>
        }

    </ChildRowContent>

    <PagerContent>
        <MudTablePager />
    </PagerContent>

</MudTable>      


<MudDialog @bind-Visible="_dialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="mr-2 mb-n1"/>
            Contenido del Camión @(_camionEnDetalle?.Placa)
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_camionEnDetalle != null && _camionEnDetalle.NotasAsignadas.Any())
        {
           <MudTable Items="@_camionEnDetalle.NotasAsignadas" Dense="true" Hover="true" Elevation="0" Outlined="true">
    <HeaderContent>
        <MudTh></MudTh> <MudTh>Documento</MudTh>
        <MudTh>Razón Social</MudTh>
        <MudTh>Cajas</MudTh>
        <MudTh>Peso</MudTh>
        <MudTh>Volumen</MudTh>
        <MudTh></MudTh> </HeaderContent>
    
    <RowTemplate Context="nota">
        <MudTd>
            <MudIconButton Icon="@(expandedDocumentoModal == nota.Documento
                                        ? Icons.Material.Filled.ExpandLess
                                        : Icons.Material.Filled.ExpandMore)"
                           OnClick="@(() => ToggleDetalleModal(nota))" 
                           Size="Size.Small"/>
        </MudTd>

        <MudTd>@nota.Documento</MudTd>
        <MudTd>@nota.RazonSocial</MudTd>
        <MudTd>@nota.CajasTotal.ToString("N0")</MudTd>
        <MudTd>@nota.PesoTotal.ToString("N2") kg</MudTd>
        <MudTd>@nota.VolumenTotal.ToString("N2") m³</MudTd>
        
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                           Color="Color.Error" 
                           Size="Size.Small" 
                           OnClick="() => RemoverNotaDeCamion(nota)"/>
        </MudTd>
    </RowTemplate>

    <ChildRowContent Context="nota">
        @if (expandedDocumentoModal == nota.Documento)
        {
            <MudTr>
                <td colspan="7">
                    <MudPaper Class="pa-3 my-2" Elevation="0" Outlined="true" Style="background-color: var(--mud-palette-background-grey);">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">
                            Artículos del documento @nota.Documento
                        </MudText>

                        <MudTable T="DetalleNotaDTO"
                                  Dense="true"
                                  Bordered="true"
                                  Elevation="0"
                                  Items="@(detalles.ContainsKey(nota.Documento) ? detalles[nota.Documento] : new List<DetalleNotaDTO>())">
                            <HeaderContent>
                                <MudTh>Artículo</MudTh>
                                <MudTh>Cajas</MudTh>
                                <MudTh>Unidades</MudTh>
                                <MudTh>Peso Unitario</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="item">
                                <MudTd>@item.Descripcion</MudTd>
                                <MudTd>@item.Cajas</MudTd>
                                <MudTd>@item.Unidades.ToString("N2")</MudTd>
                                <MudTd>@item.PesoUnitario.ToString("N2") kg</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </td>
            </MudTr>
        }
    </ChildRowContent>
</MudTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info">Este camión está vacío actualmente.</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="CerrarDetalle">Cerrar</MudButton>
    </DialogActions>
</MudDialog>

@code {

    
    private MudTable<NotaEntregaDto> table;
    private HashSet<NotaEntregaDto> notasSeleccionadas = new();
    
    private string? expandedDocumento;

    private Dictionary<string, List<DetalleNotaDTO>> detalles = new();
    
    private DateTime? _selectedDate;
   
 
    private bool loading = false;
    private bool loading2 = false;
    private string searchString = "";
   
    private TnotasentEnc? selectedNotasEntrega;
 
    private List<NotaEntregaDto> notasEntrega;
     
    private TnotasentEnc? selectedNota;
    private List<TnotasentReg> detalleNota;
    
    private List<CamionDTO> camiones = new();
    private CamionDTO? camionSeleccionado;
    
    
    // --- VARIABLES PARA EL MODAL DE DETALLES ---
    private bool _dialogVisible;
    private CamionDTO? _camionEnDetalle;
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };

    // --- MÉTODOS DEL MODAL ---
    private void AbrirDetalleCamion(CamionDTO camion)
    {
        _camionEnDetalle = camion;
        _dialogVisible = true;
    }

    private void CerrarDetalle()
    {
        _dialogVisible = false;
        _camionEnDetalle = null;
    }
    
    private async Task Buscar()
    {
        selectedNota = null;
         
        loading = true;

        try
        {
            notasEntrega = await NotasEntregaService.GetNotasEntregaByDatePesoVolumen(_selectedDate.Value);
          
        }
        finally
        {
            loading = false;
        }
 
        StateHasChanged();
    }
    
    private async Task ToggleDetalle(NotaEntregaDto nota)
    {
        var documento = nota.Documento;

        if (expandedDocumento == documento)
        {
            expandedDocumento = null;
            return;
        }

        expandedDocumento = documento;

        if (!detalles.ContainsKey(documento))
        {
            detalles[documento] = await NotasEntregaService.GetDetalleByNotaPesoVolumen(documento);
        }

        StateHasChanged();
    }
    
    
    
    protected override async Task OnInitializedAsync()
    {
        _selectedDate = DateTime.Today;
        
        camiones = await CamionService.GetAllCamionesConDespachadorAsync();
    }
  
    private bool FilterFunc(NotaEntregaDto notasEntrega)
    {
        return new[]
            {
                notasEntrega.Documento,
                notasEntrega.Rif,
                notasEntrega.RazonSocial,
                notasEntrega.Status,
                notasEntrega.Comentarios
            }
            .Any(x => (x ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase));
    }
    
    // Método para seleccionar el camión visualmente
    private void SeleccionarCamion(CamionDTO camion)
    {
        camionSeleccionado = camion;
    }

    // Lógica de colores: Verde (0-75%), Amarillo (76-99%), Rojo (100%+)
    private Color ObtenerColorCarga(double porcentaje)
    {
        if (porcentaje >= 100) return Color.Error;
        if (porcentaje >= 75) return Color.Warning;
        return Color.Success;
    }

    // Método para agregar las notas al camión
    private void AsignarNotasACamion()
    {
        if (camionSeleccionado == null || !notasSeleccionadas.Any()) return;

        // 1. Agregamos las notas seleccionadas a la lista interna del camión
        camionSeleccionado.NotasAsignadas.AddRange(notasSeleccionadas);

        // 2. Quitamos las notas de la lista general (para que desaparezcan de la tabla de abajo y no se asignen 2 veces)
        notasEntrega.RemoveAll(n => notasSeleccionadas.Contains(n));

        // 3. Limpiamos la selección de la tabla
        notasSeleccionadas.Clear();

        // 4. Forzamos a que Blazor repinte la pantalla para actualizar barras y tabla
        StateHasChanged();
    }
    
    // --- NUEVAS VARIABLES Y MÉTODOS PARA EL MODAL ---
    
    // Usamos una variable separada para el modal, así no afecta la tabla principal
    private string? expandedDocumentoModal;

    private async Task ToggleDetalleModal(NotaEntregaDto nota)
    {
        var documento = nota.Documento;

        if (expandedDocumentoModal == documento)
        {
            expandedDocumentoModal = null;
            return;
        }

        expandedDocumentoModal = documento;

        // ¡Aquí está la magia! Reutilizamos el diccionario 'detalles' que creaste 
        // al principio. Si la data ya se bajó de la base de datos, no la vuelve a pedir.
        if (!detalles.ContainsKey(documento))
        {
            detalles[documento] = await NotasEntregaService.GetDetalleByNotaPesoVolumen(documento);
        }

        StateHasChanged();
    }

    private void RemoverNotaDeCamion(NotaEntregaDto nota)
    {
        if (_camionEnDetalle != null)
        {
            // 1. Quitamos la nota del camión
            _camionEnDetalle.NotasAsignadas.Remove(nota);
            
            // 2. La devolvemos a la tabla principal para que el usuario pueda reasignarla a otro camión
            notasEntrega.Add(nota);
            
            // 3. Opcional: Mostramos una alerta de que se removió
            Snackbar.Add($"Nota {nota.Documento} retirada del camión y devuelta a la lista.", Severity.Info);
            
            StateHasChanged();

            // Si el usuario vació el camión por completo, cerramos el modal automáticamente
            if (!_camionEnDetalle.NotasAsignadas.Any())
            {
                CerrarDetalle();
            }
        }
    }
    
// ==========================================
// ESTRATEGIA 1: SOLO POR PESO (Consolidado por Cliente)
// ==========================================
private void DistribuirPorPeso()
{
    // Agrupamos por RIF, ordenamos los grupos por el peso TOTAL acumulado del cliente
    // y luego aplanamos la lista manteniendo las notas del mismo cliente juntas.
    var notasOrdenadas = notasEntrega
        .GroupBy(n => n.Rif)
        .OrderByDescending(grupo => grupo.Sum(n => n.PesoTotal))
        .SelectMany(grupo => grupo.OrderByDescending(n => n.PesoTotal))
        .ToList();
    
    Func<CamionDTO, NotaEntregaDto, bool> validacionPeso = (camion, nota) => 
        (camion.PesoActual + nota.PesoTotal) <= camion.CapacidadPesoKg;

    EjecutarAlgoritmoDistribucion(notasOrdenadas, validacionPeso, "Peso (Agrupado por Cliente)");
}

// ==========================================
// ESTRATEGIA 2: SOLO POR VOLUMEN (Consolidado por Cliente)
// ==========================================
private void DistribuirPorVolumen()
{
    // Agrupamos por RIF y ordenamos por el volumen TOTAL acumulado del cliente
    var notasOrdenadas = notasEntrega
        .GroupBy(n => n.Rif)
        .OrderByDescending(grupo => grupo.Sum(n => n.VolumenTotal))
        .SelectMany(grupo => grupo.OrderByDescending(n => n.VolumenTotal))
        .ToList();
    
    Func<CamionDTO, NotaEntregaDto, bool> validacionVolumen = (camion, nota) => 
        (camion.VolumenActual + nota.VolumenTotal) <= camion.CapacidadVolumen;

    EjecutarAlgoritmoDistribucion(notasOrdenadas, validacionVolumen, "Volumen (Agrupado por Cliente)");
}

// ==========================================
// ESTRATEGIA 3: PESO Y VOLUMEN (COMBINADO) - CORREGIDO
// ==========================================
private void DistribuirPorPesoYVolumen()
{
    // Agrupamos por RIF y ordenamos por la masa crítica total (Peso + Volumen) del cliente
    var notasOrdenadas = notasEntrega
        .GroupBy(n => n.Rif)
        .OrderByDescending(grupo => grupo.Sum(n => n.PesoTotal + n.VolumenTotal))
        .SelectMany(grupo => grupo.OrderByDescending(n => n.PesoTotal + n.VolumenTotal)) // ¡Corregido aquí!
        .ToList();
    
    Func<CamionDTO, NotaEntregaDto, bool> validacionCombinada = (camion, nota) => 
        (camion.PesoActual + nota.PesoTotal) <= camion.CapacidadPesoKg &&
        (camion.VolumenActual + nota.VolumenTotal) <= camion.CapacidadVolumen;

    EjecutarAlgoritmoDistribucion(notasOrdenadas, validacionCombinada, "Peso y Volumen (Agrupado por Cliente)");
}

// ==========================================
// MÉTODO MAESTRO CON LÓGICA DE AFINIDAD
// ==========================================
private void EjecutarAlgoritmoDistribucion(
    List<NotaEntregaDto> notasAProcesar, 
    Func<CamionDTO, NotaEntregaDto, bool> cumpleCondicion, 
    string tipoEstrategia)
{
    if (!notasEntrega.Any() || !camiones.Any())
    {
        Snackbar.Add("No hay datos suficientes para distribuir.", Severity.Warning);
        return;
    }

    int asignadas = 0;

    foreach (var nota in notasAProcesar)
    {
        // REGLA 1 (AFINIDAD): ¿Hay algún camión que YA tenga notas de este RIF y que además tenga espacio?
        var camionDestino = camiones.FirstOrDefault(c => 
            c.NotasAsignadas.Any(n => n.Rif == nota.Rif) && cumpleCondicion(c, nota));

        // REGLA 2 (FALLBACK): Si no hay camión previo para este cliente (o el que había ya se llenó),
        // buscamos el primer camión disponible de la lista que soporte la carga.
        if (camionDestino == null)
        {
            camionDestino = camiones.FirstOrDefault(c => cumpleCondicion(c, nota));
        }

        if (camionDestino != null)
        {
            camionDestino.NotasAsignadas.Add(nota);
            notasEntrega.Remove(nota);
            asignadas++;
        }
    }

    notasSeleccionadas.Clear();

    if (asignadas > 0)
    {
        if (!notasEntrega.Any())
            Snackbar.Add($"[Modo: {tipoEstrategia}] ¡Distribución optimizada por cliente completada con éxito!", Severity.Success);
        else
            Snackbar.Add($"[Modo: {tipoEstrategia}] Se asignaron {asignadas} notas agrupadas. Quedaron {notasEntrega.Count} pendientes por falta de espacio.", Severity.Warning);
    }
    else
    {
        Snackbar.Add($"[Modo: {tipoEstrategia}] Ninguna nota pudo asignarse.", Severity.Error);
    }

    StateHasChanged();
}
    
    private async Task ReiniciarDistribucion()
    {
        try
        {
            // 1. Limpiamos las selecciones manuales y los checkbox marcados
            notasSeleccionadas.Clear();
            camionSeleccionado = null;

            // 2. Vaciamos las notas acumuladas dentro de cada camión
            if (camiones != null)
            {
                foreach (var camion in camiones)
                {
                    camion.NotasAsignadas.Clear();
                }
            }

            // 3. Volvemos a consultar la base de datos
            // Esto hace que la tabla inferior recupere instantáneamente todas las notas originales
            await Buscar();

            // 4. Enviamos una alerta visual de que todo volvió a cero
            Snackbar.Add("Pantalla reiniciada. Se restableció la distribución original.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al reiniciar la distribución: {ex.Message}", Severity.Error);
        }
        finally
        {
            // 5. Refrescamos la interfaz de usuario para actualizar las barras de progreso a 0%
            StateHasChanged();
        }
    }
    
 
    
    private readonly string[] _paletaColoresClientes = new[] 
    {
        "#0D47A1", // Azul Eléctrico
        "#1B5E20", // Verde Bosque
        "#B71C1C", // Rojo Vino
        "#4A148C", // Púrpura Profundo
        "#E65100", // Naranja Tostado
        "#006064", // Azul Turquesa
        "#3E2723", // Marrón Café
        "#263238", // Gris Asfalto
        "#004D40"  // Verde Esmeralda
    };

    private string ObtenerEstiloPorCliente(NotaEntregaDto nota)
    {
        if (nota == null || string.IsNullOrEmpty(nota.Rif) || notasEntrega == null) 
            return "";

        // 1. Contamos cuántas notas de entrega tienen este mismo RIF en la tabla
        int cantidadNotasDeEsteCliente = notasEntrega.Count(n => n.Rif == nota.Rif);

        // 2. Si el cliente solo tiene una nota (NO está repetido), devolvemos texto normal
        if (cantidadNotasDeEsteCliente <= 1)
        {
            return ""; 
        }

        // 3. Si tiene más de una nota, calculamos su color para agruparlo
        int indiceColor = Math.Abs(nota.Rif.GetHashCode()) % _paletaColoresClientes.Length;
        string colorElegido = _paletaColoresClientes[indiceColor];

        return $"color: {colorElegido};";
    }

