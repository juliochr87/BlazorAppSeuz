@page "/distribucionManual"
@using BlazorAppSeuz.IServices
@using BlazorAppZeuz.Dto.NotasEntrega
@inject INotasEntregaService NotasEntregaService
@using BlazorAppZeuz.Models.Zeuz

<MudGrid AlignItems="AlignItems.Center">

    <MudItem xs="12" sm="6" md="3">
        <MudDatePicker @bind-Date="_selectedDate"
                       Margin="Margin.Dense"
                       Variant="Variant.Outlined"
                       Label="Fecha de emisión" />
    </MudItem>

    <MudItem xs="12" sm="2" Class="d-flex align-center">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Search"
                   OnClick="Buscar">
            Buscar
        </MudButton>
    </MudItem>

</MudGrid>
<br/>
 
<MudTable Outlined="true"
          @ref="table"
          T="NotaEntregaDto"
          Items="@notasEntrega"
          Dense="true"
          Hover="true"
          Loading="@loading"
          LoadingIndicator="true"
          Filter="new Func<NotaEntregaDto, bool>(FilterFunc)">

    <ToolBarContent>

        <MudText Typo="Typo.h6">
            Notas de entrega
        </MudText>

        <MudSpacer />

        <MudTextField @bind-Value="searchString"
                      Placeholder="Buscar"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Class="mt-0" />

    </ToolBarContent>

    <!-- HEADER -->
    <HeaderContent>
        <MudTh></MudTh>
        <MudTh>Documento</MudTh>
        <MudTh>RIF</MudTh>
        <MudTh>Razón Social</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Fecha Emisión</MudTh>
        <MudTh>Peso total</MudTh>
        <MudTh>Volumen total</MudTh>
        <MudTh>Comentarios</MudTh>
    </HeaderContent>

    <!-- ROW PRINCIPAL -->
    <RowTemplate Context="nota">

        <!-- BOTÓN EXPANDIR -->
        <MudTd>
            <MudIconButton Icon="@(expandedDocumento == nota.Documento
                                        ? Icons.Material.Filled.ExpandLess
                                        : Icons.Material.Filled.ExpandMore)"
                           OnClick="@(() => ToggleDetalle(nota))" />
        </MudTd>

        <MudTd>@nota.Documento</MudTd>
        <MudTd>@nota.Rif</MudTd>
        <MudTd>@nota.RazonSocial</MudTd>
        <MudTd>@nota.Status</MudTd>
        <MudTd>@nota.FechaEmision.ToString("dd/MM/yyyy")</MudTd>
        <MudTd>@nota.PesoTotal.ToString("N2")</MudTd>
        <MudTd>@nota.VolumenTotal.ToString("N2")</MudTd>
        <MudTd>@nota.Comentarios</MudTd>

    </RowTemplate>

    <!-- DETALLE EXPANDIBLE -->
    <ChildRowContent Context="nota">

        @if (expandedDocumento == nota.Documento)
        {
            <MudTr>
                <td colspan="7">

                    <MudPaper Class="pa-3">

                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                            Detalle de @nota.Documento
                        </MudText>

                        <MudTable T="DetalleNotaDTO"
                                  Dense="true"
                                  Hover="true"
                                  Bordered="true"
                                  Items="@(detalles.ContainsKey(nota.Documento)
                                            ? detalles[nota.Documento]
                                            : new List<DetalleNotaDTO>())">

                            <HeaderContent>
                                <MudTh>Id artículo</MudTh>
                                <MudTh>Artículo</MudTh>
                                <MudTh>Cajas</MudTh>
                                <MudTh>Unidades</MudTh>
                                <MudTh>Peso total</MudTh>
                                <MudTh>Volumen total</MudTh>
                                <MudTh>Status</MudTh>
                                
                            </HeaderContent>

                            <RowTemplate Context="item">
                                <MudTd>@item.IdArticulo</MudTd>
                                <MudTd>@item.Descripcion</MudTd>
                                <MudTd>@item.Cajas</MudTd>
                                <MudTd>@item.Unidades.ToString("N2")</MudTd>
                                <MudTd>
                                    <MudTooltip Text=@($"Peso unitario: {item.PesoUnitario:N2}")>
                                        @item.PesoTotal.ToString("N2")
                                    </MudTooltip>
                                </MudTd>
                              
                                <MudTd>
                                    <MudTooltip Text=@($"Volumen unitario: {item.VolumenUnitario:N2}")>
                                        @item.VolumenTotal.ToString("N2")
                                    </MudTooltip>
                                </MudTd>
                              
                                <MudTd>@item.Status</MudTd>
                            </RowTemplate>

                        </MudTable>

                    </MudPaper>

                </td>
            </MudTr>
        }

    </ChildRowContent>

    <PagerContent>
        <MudTablePager />
    </PagerContent>

</MudTable>      

@code {

    private MudTable<NotaEntregaDto> table;

    private string? expandedDocumento;

    private Dictionary<string, List<DetalleNotaDTO>> detalles = new();
    
    private DateTime? _selectedDate;
   
 
    private bool loading = false;
    private bool loading2 = false;
    private string searchString = "";
   
    private TnotasentEnc? selectedNotasEntrega;
 
    private List<NotaEntregaDto> notasEntrega;
     
    private TnotasentEnc? selectedNota;
    private List<TnotasentReg> detalleNota;
    
    private async Task Buscar()
    {
        selectedNota = null;
         
        loading = true;

        try
        {
            notasEntrega = await NotasEntregaService.GetNotasEntregaByDatePesoVolumen(_selectedDate.Value);
          
        }
        finally
        {
            loading = false;
        }
 
        StateHasChanged();
    }
    
    private async Task ToggleDetalle(NotaEntregaDto nota)
    {
        var documento = nota.Documento;

        if (expandedDocumento == documento)
        {
            expandedDocumento = null;
            return;
        }

        expandedDocumento = documento;

        if (!detalles.ContainsKey(documento))
        {
            detalles[documento] = await NotasEntregaService.GetDetalleByNotaPesoVolumen(documento);
        }

        StateHasChanged();
    }
    
    
    
    protected override async Task OnInitializedAsync()
    {
        _selectedDate = DateTime.Today;
    }
  
    private bool FilterFunc(NotaEntregaDto notasEntrega)
    {
        return new[]
            {
                notasEntrega.Documento,
                notasEntrega.Rif,
                notasEntrega.RazonSocial,
                notasEntrega.Status,
                notasEntrega.Comentarios
            }
            .Any(x => (x ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase));
    }

}