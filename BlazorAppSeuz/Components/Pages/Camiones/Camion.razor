@page "/camiones"
@using System.Net.Http.Json
@using BlazorAppSeuz.IServices
@using BlazorAppSeuz.Services
@using BlazorAppZeuz.Models.Zeuz
@inject ICamionService CamionService
@inject ISnackbar Snackbar
 
  
<MudTable Outlined="true" 
                  @ref="table"
                  EditMode="DataGridEditMode.Row"
                  Items="@camiones"
                  Dense="false"
                  Hover="true"
                  Bordered="false"
                  Striped="false"
                  CanCancelEdit="true"
                  ReadOnly="false"
                  EditTrigger="TableEditTrigger.EditButton"
                  EditButtonPosition="TableEditButtonPosition.End"
                  ApplyButtonPosition="TableApplyButtonPosition.End"
                  IsEditRowSwitchingBlocked="true"
                  Filter="new Func<Tcamiones, bool>(FilterFunc)"
                  RowEditCommit="ItemHasBeenCommitted" 
                  RowEditPreview="BackupItem"
                  RowEditCancel="ResetItemToOriginalValues"
                  @bind-SelectedItem="selectedUser">


            <ToolBarContent>
                 
                <MudText Typo="Typo.h6">Maestro de camiones</MudText>

         
                <MudSpacer />

                <MudTextField @bind-Value="searchString"
                              Placeholder="Buscar"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Class="mt-0" />
      
            </ToolBarContent>

            <HeaderContent>
                <MudTh>ID Camion</MudTh>
                <MudTh>Placa</MudTh>
                <MudTh>Descripción</MudTh>
                <MudTh>RIF</MudTh>
                <MudTh>Razón social</MudTh>
                <MudTh>Volumen</MudTh>
                <MudTh>Toneladas</MudTh>
                
            </HeaderContent>
             
            <RowTemplate>

                <MudTd DataLabel="ID Camion">@context.CamivIdcamion</MudTd>
                <MudTd DataLabel="Placa">@context.CamivPlaca</MudTd>
                <MudTd DataLabel="Descripción">@context.CamivDescripcion</MudTd>
                <MudTd DataLabel="RIF">@context.CamivRif</MudTd>
                <MudTd DataLabel="Razón social">@context.CamivRazosoci</MudTd>
                <MudTd DataLabel="Volumen">@context.CaminVolumen</MudTd>
                <MudTd DataLabel="Toneladas">@context.CaminToneladas</MudTd>
            </RowTemplate>

            <RowEditingTemplate>

                <MudTd DataLabel="Id Camion">
                    <MudTextField @bind-Value="context.CamivIdcamion" Required="true" Disabled="true"  />
                </MudTd>

                <MudTd DataLabel="Placa">
                    <MudTextField @bind-Value="context.CamivPlaca" Required="true" />
                </MudTd>
 
                <MudTd DataLabel="Descripcion">
                    <MudTextField @bind-Value="context.CamivDescripcion"
                                  Required="false" />
                </MudTd>
 
                <MudTd DataLabel="RIF">
                    <MudTextField @bind-Value="context.CamivRif" />
                </MudTd>
                
                <MudTd DataLabel="Razón social">
                    <MudTextField @bind-Value="context.CamivRazosoci" />
                </MudTd>
                
                <MudTd DataLabel="Volumen">
                    <MudTextField @bind-Value="context.CaminVolumen" />
                </MudTd>
                
                <MudTd DataLabel="Toneladas">
                    <MudTextField @bind-Value="context.CaminToneladas" />
                </MudTd>
 
            </RowEditingTemplate>
            
            <PagerContent>

                <MudTablePager>
           
                </MudTablePager>
          
            </PagerContent>
 

        </MudTable>

        

@code {

    private MudTable<Tcamiones> table;
    private bool isEditing = false;
    private bool _showDeletedUsers;

    private bool showDeletedUsers
    {
        get => _showDeletedUsers;
        set
        {
            if (_showDeletedUsers != value)
            {
                _showDeletedUsers = value;
                OnShowDeletedChanged();
            }
        }
    }

    private async Task OnShowDeletedChanged()
    {
        // ejemplo: recargar datos
        await LoadUsers();
    }

    private string searchString = "";
    public string passwordX = Constants.passwordxxx;
    private Tcamiones? selectedUser;

    private Tcamiones elementBeforeEdit;


    private List<Tcamiones> camiones = new();

    private async Task LoadUsers()
    {
        camiones = await CamionService.GetAllAsync();
 
        StateHasChanged();
    }
     
    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadUsers();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error cargando usuarios: {ex.Message}", Severity.Error);
        }
    }

    private async Task AddNewUser()
    {
    }

    private async Task DeleteItem(Tcamiones user)
    {
    }

    private async void BackupItem(object element)
    {
        isEditing = true;
       
        elementBeforeEdit = new()
        {
           
           // UsuavPassword = Constants.passwordxxx,
          
        };
        
        StateHasChanged();
    }

    private async void ResetItemToOriginalValues(object element)
    {
        isEditing = false;
        await LoadUsers();
        StateHasChanged();
    }

    private async void ItemHasBeenCommitted(object userObj)
    {

        try
        {
            
            var user = (Tcamiones)userObj;

            

            if (user.CamivIdcamion.Equals(0))
            {
                // ES NUEVO → CREATE
                //await UserService.CreateAsync(user);
                Snackbar.Add("User created", Severity.Success);

                isEditing = false;
               
            }
            else
            {
                // EXISTENTE → UPDATE
                await CamionService.UpdateAsync(user);
                Snackbar.Add("Usuario actualizado", Severity.Success);
            }

            isEditing = false;
            await LoadUsers();
            StateHasChanged();

        }
        catch
        {
            Snackbar.Add("Error updating the user", Severity.Error);
           
        }
    }

    private async Task UpdateItem(Tcamiones user)
    {
        try
        {
           // await UserService.UpdateAsync(user.Id, user);
            await LoadUsers();
            Snackbar.Add("User updated", Severity.Success);
           

        }
        catch
        {
            Snackbar.Add("Error updating the user", Severity.Error);
        }
    }

    private bool FilterFunc(Tcamiones camion)
    {
        return new[]
            {
                camion.CamivIdcamion,
                camion.CamivDescripcion,
                camion.CamivPlaca,
                camion.CamivRif,
                camion.CamivRazosoci,
                camion.CaminVolumen?.ToString(),
                camion.CaminToneladas?.ToString(),
            }
            .Any(x => (x ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase));
    }

}